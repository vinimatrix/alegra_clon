# ============================================================
# ALEGRA+ ERP - Variables de Entorno
# ============================================================
# Copia este archivo a .env y completa los valores reales.
# NUNCA subas el archivo .env real al repositorio.
# ============================================================

# --- GEMINI AI ---
# Requerido para llamadas a la API de Gemini AI.
# Configúralo en el panel de Secrets si usas AI Studio.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# --- GENERAL ---
# URL donde está alojada esta aplicación (Cloud Run, Vercel, etc.)
APP_URL="MY_APP_URL"

# ============================================================
# BACKEND DUAL: SUPABASE vs. API LOCAL (NestJS)
# ============================================================

# --- MODO DE BACKEND ---
# Pon "true" para usar Supabase Cloud.
# Pon "false" (o no lo definas) para usar el mock local o NestJS.
VITE_USE_SUPABASE="true"

# --- SUPABASE ---
# Obtén estos valores desde: https://supabase.com/dashboard → Settings → API
VITE_SUPABASE_URL="https://lfqtukghugjvqgwdjklq.supabase.co"
VITE_SUPABASE_ANON_KEY="teyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImxmcXR1a2dodWdqdnFnd2Rqa2xxIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODAwNzU3NDIsImV4cCI6MjA5NTY1MTc0Mn0.qn6myAYAiw4rK88NayGgQUYZoIY0FILaehboqB7TeBY"

# --- BACKEND LOCAL (NestJS / Express) ---
